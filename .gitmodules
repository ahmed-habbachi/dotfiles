	path = tmux/.config/tmux/plugins/tmux-resurrect
	url = git@github.com:tmux-plugins/tmux-resurrect.git
[submodule "tmux/.config/tmux/plugins/tmux-sessionx"]
	path = tmux/.config/tmux/plugins/tmux-sessionx
	url = git@github.com:omerxx/tmux-sessionx.git
[submodule "tmux/.config/tmux/plugins/tmux-yank"]
	path = tmux/.config/tmux/plugins/tmux-yank
	url = git@github.com:tmux-plugins/tmux-yank.git
[submodule "tmux/.config/tmux/plugins/tpm"]
	path = tmux/.config/tmux/plugins/tpm
	url = git@github.com:tmux-plugins/tpm.git
[submodule "tmux/.config/tmux/plugins/vim-tmux-navigator"]
